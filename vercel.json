{
    "version": 2,
    "builds": [
          { "src": "api/webhook.js", "use": "@vercel/node" },
          { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
          { "src": "/api/webhook", "dest": "/api/webhook.js" },
          { "src": "/quiz", "dest": "/public/quiz.html" },
          { "src": "/obrigado", "dest": "/public/obrigado.html" },
          { "src": "/", "dest": "/public/index.html" },
          { "src": "/(.*)\\.html", "dest": "/public/$1.html" },
          { "src": "/(.*)", "dest": "/public/$1" }
    ]
}
